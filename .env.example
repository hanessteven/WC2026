# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# Supabase project URL (found in Supabase dashboard > Settings > API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (found in Supabase dashboard > Settings > API)
SUPABASE_KEY=your-anon-key-here

# Supabase service role key — used ONLY for admin writes (bypasses RLS).
# Found in Supabase dashboard > Settings > API > service_role key.
# Never commit this or expose it to the browser.
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Comma-separated list of admin email addresses
ADMIN_EMAILS=you@example.com,other-admin@example.com